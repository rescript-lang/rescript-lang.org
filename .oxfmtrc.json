{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": [
    "!_shims.mjs",
    "!public/_redirects",
    ".DS_Store",
    ".worktrees/",
    ".next/",
    ".react-router",
    "*.swo",
    "*.swp",
    "app/**/*.mjs",
    "build",
    "data/api/**/*.json",
    "dist",
    "index_data/*.json",
    "node_modules/",
    "out/",
    "public/playground-bundles/",
    "public/blog/feed.xml",
    "_tempFile.cmi",
    "_tempFile.cmj",
    "_tempFile.cmt",
    "_tempFile.res",
    "temp",
    ".bsb.lock",
    ".merlin",
    "lib/",
    ".vercel",
    "src/**/*.mjs",
    "scripts/gendocs.mjs",
    "scripts/generate_*.mjs",
    "public/llms/manual/**/llm*.txt",
    "public/llms/react/**/llm*.txt",
    "pages/docs/**/**/llms.mdx",
    "markdown-pages/docs/manual/installation.mdx",
    ".yarn/releases/yarn-4.12.0.cjs",
    "data/api/*"
  ]
}
